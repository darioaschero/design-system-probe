{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "vendor/nuri-design-system/build/**/*.ts",
    "vendor/nuri-design-system/docs/migration-tests/button-matrix/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "vendor/nuri-design-system/docs/migration-tests/button-matrix/react-native-svg.d.ts"
  ]
}
