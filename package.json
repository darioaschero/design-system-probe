  "private": true,
  "description": "Nuri DS integration probe — deliberately mirrors nuri-expo's stack (Expo 53 · RN 0.79.6 · React 19.0 · TS 5.8) to validate that a vendored @nuri/rn tag compiles, bundles, and renders there. Not a demo app.",
  "main": "index.ts",
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "expo": "~53.0.27",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  },
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "ds:pull": "node tools/ds-pull.mjs"
  }
